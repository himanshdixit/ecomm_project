NODE_ENV=production
PORT=5000
MONGO_URI=mongodb+srv://your-user:your-password@your-cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=Codex_ecomm_db
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000,https://ecomm-project-frontend-fkpb.vercel.app
# Optional: allow preview deployments for the same Vercel project
# CLIENT_URL_PATTERNS=https://ecomm-project-frontend-fkpb-*.vercel.app
REQUEST_BODY_LIMIT=1mb
AUTH_COOKIE_SAME_SITE=none
AUTH_COOKIE_SECURE=true
